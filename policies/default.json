[
  {
    "id": "block-rm-rf",
    "name": "阻止递归删除根目录",
    "priority": 100,
    "severity": "critical",
    "match": { "type": "tool_call", "tool": "terminal", "args_pattern": "rm -rf /" },
    "action": "block",
    "reason": "高危：递归删除根目录"
  },
  {
    "id": "block-dd-write",
    "name": "阻止 dd 直接写块设备",
    "priority": 95,
    "severity": "critical",
    "match": { "type": "tool_call", "tool": "terminal", "args_pattern": "dd if=.*of=(/dev|/tmp|/opt|/usr|/etc|/root|/home)" },
    "action": "block",
    "reason": "高危：直接写块设备"
  },
  {
    "id": "block-credential-files",
    "name": "阻止读取凭证文件",
    "priority": 90,
    "severity": "high",
    "match": { "type": "tool_call", "tool": "read_file", "args_pattern": "(\\.ssh|credentials|\\.aws|/etc/shadow|/etc/passwd|token|secret)" },
    "action": "block",
    "reason": "检测到凭证文件访问"
  },
  {
    "id": "block-reverse-shell",
    "name": "阻止反向 Shell",
    "priority": 95,
    "severity": "critical",
    "match": { "type": "tool_call", "tool": "terminal", "args_pattern": "(bash -i.*/dev/tcp|nc .*-e |ncat.*-e |socat.*exec|mkfifo)" },
    "action": "block",
    "reason": "检测到反向 Shell"
  },
  {
    "id": "block-data-exfil",
    "name": "阻止数据外传命令",
    "priority": 85,
    "severity": "high",
    "match": { "type": "tool_call", "tool": "terminal", "args_pattern": "(curl.*-d @|curl.*--data @|wget.*--post-file|nc [0-9]+\\.[0-9]+)" },
    "action": "block",
    "reason": "检测到数据外传"
  },
  {
    "id": "block-curl-pipe-bash",
    "name": "阻止 curl/bash 远程执行",
    "priority": 90,
    "severity": "critical",
    "match": { "type": "tool_call", "tool": "terminal", "args_pattern": "curl.*\\| (bash|sh)" },
    "action": "block",
    "reason": "高危：远程下载后执行"
  },
  {
    "id": "block-port-scan",
    "name": "阻止端口扫描",
    "priority": 70,
    "severity": "medium",
    "match": { "type": "tool_call", "tool": "terminal", "args_pattern": "^(nmap|masscan|zmap)" },
    "action": "block",
    "reason": "检测到端口扫描工具"
  },
  {
    "id": "block-cron-persist",
    "name": "阻止定时任务持久化",
    "priority": 85,
    "severity": "high",
    "match": { "type": "tool_call", "tool": "terminal", "args_pattern": "(crontab|cron\b|at\b|systemctl.*timer|schtasks)" },
    "action": "block",
    "reason": "检测到定时任务持久化"
  },
  {
    "id": "block-ssh-backdoor",
    "name": "阻止 SSH 后门安装",
    "priority": 90,
    "severity": "critical",
    "match": { "type": "tool_call", "tool": "terminal", "args_pattern": "(authorized_keys|ssh-keygen|ssh-copy-id|.ssh/)" },
    "action": "block",
    "reason": "检测到 SSH 后门安装"
  },
  {
    "id": "block-wget-curl-download",
    "name": "阻止 wget/curl 下载到系统目录",
    "priority": 80,
    "severity": "high",
    "match": { "type": "tool_call", "tool": "terminal", "args_pattern": "(wget|curl).*-[Oo] /(usr|etc|opt|root)" },
    "action": "block",
    "reason": "检测到下载文件到系统目录"
  },
  {
