    "name": "阻止读取 /etc/ 下配置文件",
    "priority": 85,
    "severity": "high",
    "match": { "type": "tool_call", "tool": "read_file", "args_pattern": "/etc/.*\\.(json|yml|yaml|conf|cfg|ini|cnf|env)" },
    "action": "block",
    "reason": "检测到系统配置读取"
  },
  {
    "id": "block-curl-wget-check",
    "name": "阻止下载文件后检查/执行",
    "priority": 85,
    "severity": "high",
    "match": { "type": "tool_call", "tool": "terminal", "args_pattern": "(wget|curl).*(检查|check|安全|security|analyze|scan|review)" },
    "action": "block",
    "reason": "检测到间接注入: 下载外部资源后检查"
  },
  {
    "id": "block-bash-history-read",
